# Idea Factory — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables are optional except your chosen provider's API key.

# --- LLM Provider ---
# IDEA_FACTORY_LLM_PROVIDER=anthropic      # "anthropic", "openai", or "gemini"
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# GEMINI_KEY=AIza...                       # alias for GEMINI_API_KEY
# IDEA_FACTORY_MODEL=claude-sonnet-4-6     # or gpt-4o, gemini-3.1-pro-preview, etc.

# --- Database ---
# IDEA_FACTORY_DB_PATH=~/.idea-factory/ideas.db

# --- Pipeline Tuning ---
# IDEA_FACTORY_TOP_K=2                      # survivors advancing to full eval per loop
# IDEA_FACTORY_MAX_WINNERS=10               # stop interactive mode after N winners
# IDEA_FACTORY_MAX_RETRIES=2                # JSON parse retries per LLM call
# IDEA_FACTORY_REFLEXION_MAX_ROUNDS=2       # self-critique rounds for Challenger/Judge
# IDEA_FACTORY_TRENDING_CACHE_TTL=600       # trending topic cache (seconds)
# IDEA_FACTORY_PACE_BETWEEN_IDEAS=2.0       # livestream delay between ideas (seconds)
# IDEA_FACTORY_PACE_BETWEEN_LOOPS=5.0       # livestream delay between loops (seconds)

# --- Logging ---
# IDEA_FACTORY_LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
# IDEA_FACTORY_LOG_FILE=~/.idea-factory/idea-factory.log

# --- Verbose output ---
# IDEA_FACTORY_VERBOSE=false
